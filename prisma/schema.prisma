// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum CaseStatus {
  active
  archived
}

model Case {
  id        String     @id
  status    CaseStatus @default(active)
  sortOrder Int

  createdAt  DateTime
  updatedAt  DateTime
  archivedAt DateTime?
  deletedAt  DateTime?

  itemCode String
  itemName String?

  supplier  String?
  replyDate String?
  dueDate   String?
  delayDays Int?
  orderCode String?
  quantity  Int?
  warehouse String?
  deadline  String?
  cause     String?
  note      String?
}